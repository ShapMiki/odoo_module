<odoo>

     <!-- Канбан -->
    <record id="view_event_kanban" model="ir.ui.view">
        <field name="name">event.event.kanban</field>
        <field name="model">event.event</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong><t t-esc="record.full_title.value"/></strong>
                                <span>Price: <t t-esc="record.price.value" /></span>
                            </div>
                            <div>
                                <span t-if="record.is_available.value" style="color: green;">✅ Доступна</span>
                                <span t-else="" style="color: red;">❌ На руках</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>    
    </record>


    <!-- Список книг (Tree View) -->
    <record id="view_library_book_tree" model="ir.ui.view">
        <field name="name">library.book.tree</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Library Books">
                <field name="title"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="is_available"/>
                <field name="count_pages"/>
                <field name="large_type"/>
                <field name="full_title"/>
            </list>
        </field>
    </record>

    <!-- Форма книги (Form View) -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
        
            <form string="Library Book">
                <sheet>
                    <div>
                        <span style="color: red;">БИБЛИОТЕКА</span>
                    </div>

                    <group>
                        <field name="title"/>
                        <field name="author"/>
                        <field name="count_pages"/>
                        <field name="isbn"/>
                        <field name="description"/>
                        <field name="published_date"/>
                        <field name="is_available" statusbar_visible="True, False"
                        statusbar_colors="True:red,False:green"/>
                        <field name="price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        <field name="image" widget="image"/>
                    </group>
                     <header>
                            <button name="action_mark_as_featured" 
                                string="Confirm" 
                                type="object" 
                                class="oe_highlight"
                                invisible="is_available == True"/>
                    </header>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Поиск (Search View) -->
    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search string="Search Library Books">
                <field name="title" string="Title"/>
                <field name="author" string="Author"/>
                <field name="isbn" string="ISBN"/>
                <filter name="available" string="Available" domain="[('is_available','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_author" string="Author" context="{'group_by':'author'}"/>
                    <filter name="group_available" string="Availability" context="{'group_by':'is_available'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Действие -->
    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Library Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Меню -->
    <menuitem id="menu_library_root" name="Library"/>
    <menuitem id="menu_library_books" name="Books" parent="menu_library_root" action="action_library_book"/>
</odoo>