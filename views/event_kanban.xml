<odoo>


     <!-- Канбан -->
    <record id="view_event_kanban" model="ir.ui.view">
        <field name="name">library.book.kanban</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="title"/>
                <field name="author"/>
                <field name="is_available"/>
                <field name="full_title"/>
                <field name="price"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong><t t-esc="record.full_title.value"/></strong>
                                <span>Price: <t t-esc="record.price.value" /></span>
                            </div>
                            <div>
                                <span t-if="record.is_available.value" style="color: green;">✅ Доступна</span>
                                <span t-else="" style="color: red;">❌ На руках</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>    
    </record>


     <record id="action_library_book_kanban" model="ir.actions.act_window">
        <field name="name">Books Kanban View</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">kanban,form</field>
        <field name="view_id" ref="view_event_kanban"/>
    </record>

    <!-- Меню для канбан-представления -->
    <menuitem id="menu_library_books_kanban" 
              name="Books Kanban" 
              parent="menu_library_root" 
              action="action_library_book_kanban"
              sequence="20"/>
</odoo>
